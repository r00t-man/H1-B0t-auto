# ──────────────────────────────────────────────────────────────────────────
# H1-B0t-auto — конфигурация
#
# Скопируй этот файл в .env и заполни. Мастер установки (setup_wizard.py)
# делает это интерактивно и объясняет каждый пункт, но .env можно
# редактировать вручную в любой момент — просто перезапусти сервис:
#   systemctl restart h1-b0t-auto
#
# Пустое значение = соответствующая функция бота выключена (меню скрывает
# недоступные кнопки), а не падает с ошибкой. Обязательны только два поля
# в самом первом блоке — всё остальное можно дозаполнить позже.
# ──────────────────────────────────────────────────────────────────────────

# ── Telegram (обязательно) ──────────────────────────────────────────────
# Токен бота — получить у @BotFather (/newbot). Без него бот не запустится.
TELEGRAM_BOT_TOKEN=

# ID пользователей Telegram, которым разрешено пользоваться ботом
# (через запятую, без пробелов). Узнать свой id можно у @userinfobot.
# Первый в списке считается основным админом.
ADMIN_IDS=

# ── H1cloud Client API (рекомендуется) ──────────────────────────────────
# Даёт: список серверов, живые метрики (CPU/RAM/uptime), питание
# (старт/стоп/рестарт), баланс, продление аренды, обновление ядра Xray,
# перевыпуск REALITY-ключей. Это основной и самый полный API h1cloud.
#
# Как получить: залогинься на https://my.h1cloud.net/, открой
# https://my.h1cloud.net/api-docs — там генерируется Bearer-ключ вида h1_...
H1CLOUD_CLIENT_API_URL=https://my.h1cloud.net
H1CLOUD_CLIENT_API_KEY=

# ── H1cloud panel — логин сайта (опционально) ────────────────────────────
# НЕ то же самое, что API-ключ выше — это обычные логин/пароль от личного
# кабинета https://my.h1cloud.net/. Нужны ТОЛЬКО для одной функции: кнопки
# «Создать новый конфиг» — у h1cloud нет API-эндпоинта для этого действия,
# и единственный способ его выполнить программно — открыть headless-браузер
# (Playwright) и нажать кнопку так же, как это делает живой человек.
# Если оставить пустым — эта кнопка просто не появится в меню, остальной
# функционал бота не пострадает.
H1CLOUD_PANEL_LOGIN=
H1CLOUD_PANEL_PASSWORD=

# ── H1cloud Pelican API (устаревший, опционально) ────────────────────────
# Старая панель прямого управления контейнером (panel.h1cloud.net).
# Актуально только если у тебя ЕСТЬ доступ именно к этой панели, а Client
# API (выше) недоступен или не устраивает. Для большинства пользователей
# не нужен — Client API покрывает то же самое и больше.
H1CLOUD_PELICAN_API_URL=https://panel.h1cloud.net
H1CLOUD_PELICAN_API_TOKEN=

# ── Remnawave (опционально) ──────────────────────────────────────────────
# Нужно только если хочешь, чтобы бот сам обновлял CDN-домен/REALITY-ключи
# в твоей панели Remnawave при ротации гейтвея на стороне h1cloud —
# конкретные привязки "какой h1cloud-сервер → какой Remnawave-хост"
# настраиваются отдельно в bindings.json (см. bindings.example.json).
# Если оставить пустым — бот будет управлять только самими h1cloud-серверами,
# без синхронизации с Remnawave.
REMNAWAVE_API_URL=
REMNAWAVE_API_TOKEN=

# ── Интервалы фоновых проверок (в секундах) ──────────────────────────────
# Как часто проверять, не сменился ли домен CDN-гейтвея у h1cloud-серверов
# из bindings.json (актуально только если Remnawave выше настроен).
GATEWAY_CHECK_INTERVAL=900

# Как часто проверять новые посты в публичном канале провайдера
# https://t.me/h1cloud_status (объявления о технических работах/восстановлении).
CHANNEL_CHECK_INTERVAL=300
